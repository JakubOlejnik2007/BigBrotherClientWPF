<Window x:Class="BigBrotherClientWPF.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zablokowane"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Black"
        KeyDown="Window_KeyDown">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="Aplikacja zablokowana"
                       Foreground="White"
                       FontSize="30"
                       HorizontalAlignment="Center" />

            <PasswordBox x:Name="PinBox"
                         Width="200"
                         Margin="0,20,0,0" />

            <Button Content="Odblokuj"
                    Width="200"
                    Margin="0,10,0,0"
                    Click="Unlock_Click" />
        </StackPanel>
    </Grid>
</Window>